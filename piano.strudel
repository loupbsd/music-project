stack(
note("c2 [~ d#2] f2 ~ [f#2 g2] ~ c2 c3")
  .s("mon_piano")
  .attack(0.5)
  .release(1)
  .crush(4)       // Réduit la qualité à 4 bits (son de jeu vidéo rétro / machine)
  .shape(0.2)     // Ajoute de la distorsion pour réchauffer et salir le son
  .lpf(sine.range(400, 3000).slow(2)) 
  .lpq(3)
  .room(0.6).sz(0.8) // Grosse réverbération spatiale
  .gain("0.8"),
s("akaimpc60_misc:2*4").lpf(500).gain(0.5),